{
  "connection": "default",
  "collectionName": "blogposts",
  "info": {
    "name": "blogpost",
    "description": ""
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "comment": ""
  },
  "attributes": {
    "Title": {
      "default": "",
      "type": "string"
    },
    "Content": {
      "default": "",
      "type": "text"
    },
    "Likes": {
      "default": "",
      "type": "integer"
    },
    "Dislikes": {
      "default": "",
      "type": "integer"
    },
    "CoverImage": {
      "model": "file",
      "via": "related",
      "plugin": "upload",
      "required": false
    },
    "Category": {
      "default": "",
      "type": "enumeration",
      "enum": [
        "Technology",
        "Programming",
        "Politics"
      ]
    },
    "Sort": {
      "default": "",
      "type": "integer"
    }
  }
}